# Copy to .env.local for local dev. Set the same keys in Vercel (Production + Preview).
# Never commit .env.local. Get values from Supabase: Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (Route Handlers). Optional until Phase 4 if unused.
SUPABASE_SERVICE_ROLE_KEY=

# Phase 3: fine-grained PAT for catalogue JSON commits (server-only, not NEXT_PUBLIC_).
GITHUB_TOKEN=
