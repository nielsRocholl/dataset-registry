# Copy to .env.local for local dev. Set the same keys in Vercel (Production + Preview).
# Never commit .env.local. Get values from Supabase: Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only (Route Handlers and admin membership). Required for live app.
SUPABASE_SERVICE_ROLE_KEY=

# Optional emergency bootstrap list; manage normal access from /datasets/admin.
CATALOGUE_BOOTSTRAP_ADMIN_EMAILS=

# Phase 3 — GitHub Contents API (server-only, never NEXT_PUBLIC_*).
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_DEFAULT_BRANCH=

# Optional non-production smoke / local curl only. Ignored when VERCEL_ENV is production.
CATALOGUE_E2E_BEARER=
